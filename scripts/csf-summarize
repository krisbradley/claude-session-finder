#!/usr/bin/env python3
"""
Generate extractive summaries for Claude Code sessions using sumy.
No model download required — pure algorithmic summarization.

Install: pip install sumy

Usage:
    csf-summarize          # Summarize new sessions
    csf-summarize --all    # Regenerate all summaries
"""

import json
import sys
import argparse
from pathlib import Path
from datetime import datetime
from collections import defaultdict

CLAUDE_DIR = Path.home() / '.claude'
HISTORY_FILE = CLAUDE_DIR / 'history.jsonl'
SUMMARIES_FILE = CLAUDE_DIR / 'csf-summaries.json'
MIN_MESSAGES = 3


def load_sessions():
    sessions = defaultdict(list)
    with open(HISTORY_FILE) as f:
        for line in f:
            try:
                entry = json.loads(line.strip())
                sid = entry.get('sessionId')
                if sid:
                    sessions[sid].append(entry)
            except Exception:
                pass
    return sessions


def build_input_text(entries):
    entries = sorted(entries, key=lambda x: x['timestamp'])
    messages = [e.get('display', '').strip() for e in entries if e.get('display', '').strip()]
    messages = [m for m in messages if len(m) > 3]
    if len(messages) < MIN_MESSAGES:
        return None
    return '. '.join(messages)


def load_cache():
    if SUMMARIES_FILE.exists():
        try:
            return json.loads(SUMMARIES_FILE.read_text())
        except Exception:
            pass
    return {}


def save_cache(cache):
    SUMMARIES_FILE.write_text(json.dumps(cache, indent=2))


def content_hash(entries):
    msgs = ''.join(e.get('display', '') for e in entries)
    return str(hash(msgs) & 0xFFFFFFFF)


def make_summarizer():
    try:
        from sumy.summarizers.lsa import LsaSummarizer
        from sumy.nlp.stemmers import Stemmer
        from sumy.utils import get_stop_words
        stemmer = Stemmer('english')
        summarizer = LsaSummarizer(stemmer)
        summarizer.stop_words = get_stop_words('english')
        return summarizer
    except Exception as e:
        print(f"Error setting up summarizer: {e}")
        sys.exit(1)


def summarize(text, summarizer):
    from sumy.parsers.plaintext import PlaintextParser
    from sumy.nlp.tokenizers import Tokenizer

    parser = PlaintextParser.from_string(text, Tokenizer('english'))
    sentences = summarizer(parser.document, 1)
    if not sentences:
        return None
    summary = str(sentences[0]).strip()
    if len(summary) > 80:
        summary = summary[:77] + '...'
    return summary


def ensure_nltk_punkt():
    """Download punkt tokenizer data if needed (small, ~13MB)."""
    import nltk
    try:
        nltk.data.find('tokenizers/punkt')
    except LookupError:
        print("Downloading NLTK punkt tokenizer data (~13MB, one-time)...")
        nltk.download('punkt', quiet=True)
    try:
        nltk.data.find('tokenizers/punkt_tab')
    except LookupError:
        nltk.download('punkt_tab', quiet=True)


def main():
    parser = argparse.ArgumentParser(description='Generate summaries for Claude sessions')
    parser.add_argument('--all', action='store_true', help='Regenerate all summaries')
    args = parser.parse_args()

    try:
        import sumy  # noqa: F401
    except ImportError:
        print("sumy is not installed. Run: pip install sumy")
        sys.exit(1)

    ensure_nltk_punkt()

    if not HISTORY_FILE.exists():
        print("No Claude Code history found.")
        sys.exit(1)

    print("Loading sessions...")
    sessions = load_sessions()
    cache = {} if args.all else load_cache()

    to_summarize = []
    for session_id, entries in sessions.items():
        if len(entries) < MIN_MESSAGES:
            continue
        chash = content_hash(entries)
        cached = cache.get(session_id, {})
        if not args.all and cached.get('hash') == chash and cached.get('summary'):
            continue
        text = build_input_text(entries)
        if text:
            to_summarize.append((session_id, entries, text, chash))

    if not to_summarize:
        print("All sessions already summarized.")
        return

    summarizer = make_summarizer()
    print(f"Summarizing {len(to_summarize)} sessions...\n")

    for i, (session_id, entries, text, chash) in enumerate(to_summarize, 1):
        latest = max(entries, key=lambda x: x['timestamp'])
        project = latest.get('project', '')
        try:
            p = Path(project)
            if p.is_relative_to(Path.home()):
                project = str(p.relative_to(Path.home()))
        except Exception:
            pass

        print(f"[{i}/{len(to_summarize)}] {session_id[:8]}... ({project})")

        summary = summarize(text, summarizer)
        if summary:
            print(f"  → {summary}\n")
            cache[session_id] = {
                'summary': summary,
                'hash': chash,
                'generated_at': datetime.now().isoformat(),
                'backend': 'sumy/lsa',
            }
            save_cache(cache)
        else:
            print(f"  ✗ Could not summarize\n")

    total = sum(1 for v in cache.values() if v.get('summary'))
    print(f"Done. {total} summaries cached in {SUMMARIES_FILE}")


if __name__ == '__main__':
    main()
