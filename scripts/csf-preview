#!/usr/bin/env python3
"""Preview script for claude-sessions fzf integration"""

import os
import sys
import json
from pathlib import Path
from datetime import datetime

CLAUDE_DIR = Path(os.environ.get('CLAUDE_CONFIG_DIR', Path.home() / '.claude'))
HISTORY_FILE = CLAUDE_DIR / 'history.jsonl'
DEBUG_DIR = CLAUDE_DIR / 'debug'

W = int(os.environ.get('FZF_PREVIEW_COLUMNS', 70)) - 2


def load_ai_title(session_id):
    projects_dir = CLAUDE_DIR / 'projects'
    if not projects_dir.exists():
        return None
    for proj_dir in projects_dir.iterdir():
        if not proj_dir.is_dir():
            continue
        f = proj_dir / f"{session_id}.jsonl"
        if not f.exists():
            continue
        title = None
        try:
            for line in f.open():
                if '"ai-title"' in line:
                    data = json.loads(line)
                    if data.get('type') == 'ai-title' and data.get('aiTitle'):
                        title = data['aiTitle']
                elif '"custom-title"' in line:
                    data = json.loads(line)
                    if data.get('type') == 'custom-title' and data.get('customTitle'):
                        return data['customTitle']
        except Exception:
            pass
        return title
    return None


def parse_timestamp(ts: int) -> datetime:
    return datetime.fromtimestamp(ts / 1000)


def format_duration(delta) -> str:
    total_seconds = int(delta.total_seconds())
    if total_seconds < 60:
        return f"{total_seconds}s"
    elif total_seconds < 3600:
        return f"{total_seconds // 60}m {total_seconds % 60}s"
    elif total_seconds < 86400:
        hours = total_seconds // 3600
        minutes = (total_seconds % 3600) // 60
        return f"{hours}h {minutes}m"
    else:
        days = total_seconds // 86400
        hours = (total_seconds % 86400) // 3600
        return f"{days}d {hours}h"


def main():
    if len(sys.argv) < 2:
        print("Usage: csf-preview <session-id>")
        sys.exit(1)

    session_id = sys.argv[1]

    # Load session entries from history
    entries = []
    try:
        with open(HISTORY_FILE, 'r') as f:
            for line in f:
                try:
                    entry = json.loads(line.strip())
                    if entry.get('sessionId') == session_id:
                        entries.append(entry)
                except:
                    pass
    except:
        pass

    if not entries:
        print("=" * W)
        print(f"SESSION: {session_id}")
        print("=" * W)
        print("❌ No session data found")
        sys.exit(0)

    # Sort by timestamp
    entries.sort(key=lambda x: x['timestamp'])

    # Session metadata
    msg_count = len(entries)
    start_time = parse_timestamp(entries[0]['timestamp'])
    end_time = parse_timestamp(entries[-1]['timestamp'])
    duration = end_time - start_time
    project = entries[-1].get('project', 'Unknown')

    # Print header
    title = load_ai_title(session_id)
    print("=" * W)
    if title:
        words = title.split()
        line, wrapped = [], []
        for word in words:
            if sum(len(w) + 1 for w in line) + len(word) > W - 4:
                wrapped.append(' '.join(line))
                line = [word]
            else:
                line.append(word)
        if line:
            wrapped.append(' '.join(line))
        for l in wrapped:
            print(f"  {l}")
        print("=" * W)
    print(f"📁 Project:   {project}")
    print(f"📅 Started:   {start_time.strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"⏱️  Duration:  {format_duration(duration)}")
    print(f"💬 Messages:  {msg_count}")
    print("=" * W)
    print()

    # Show conversation
    print("─" * W)
    shown = 0
    for entry in entries[:20]:
        msg = entry.get('display', '').strip()
        if not msg:
            continue

        ts = parse_timestamp(entry['timestamp'])
        time_str = ts.strftime('%H:%M')
        prefix = f" {time_str}  "
        max_msg = W - len(prefix)
        if len(msg) > max_msg:
            msg = msg[:max_msg - 3] + "..."

        print(f"{prefix}{msg}")
        shown += 1

    remaining = len(entries) - shown
    if remaining > 0:
        print(f"  ... +{remaining} more")

    print("=" * W)
    print()
    DIM = '\033[2m'
    R = '\033[0m'
    print(f"{DIM}enter open  ^d delete  ^e export  ^y copy id  ^p project{R}")


if __name__ == '__main__':
    main()
