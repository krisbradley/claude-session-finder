#!/usr/bin/env python3
"""Preview script for claude-sessions fzf integration"""

import sys
import json
from pathlib import Path
from datetime import datetime

CLAUDE_DIR = Path.home() / '.claude'
HISTORY_FILE = CLAUDE_DIR / 'history.jsonl'
SUMMARIES_FILE = CLAUDE_DIR / 'csf-summaries.json'
DEBUG_DIR = CLAUDE_DIR / 'debug'


def load_summary(session_id):
    try:
        data = json.loads(SUMMARIES_FILE.read_text())
        return data.get(session_id, {}).get('summary')
    except Exception:
        return None


def parse_timestamp(ts: int) -> datetime:
    return datetime.fromtimestamp(ts / 1000)


def format_duration(delta) -> str:
    total_seconds = int(delta.total_seconds())
    if total_seconds < 60:
        return f"{total_seconds}s"
    elif total_seconds < 3600:
        return f"{total_seconds // 60}m {total_seconds % 60}s"
    elif total_seconds < 86400:
        hours = total_seconds // 3600
        minutes = (total_seconds % 3600) // 60
        return f"{hours}h {minutes}m"
    else:
        days = total_seconds // 86400
        hours = (total_seconds % 86400) // 3600
        return f"{days}d {hours}h"


def main():
    if len(sys.argv) < 2:
        print("Usage: csf-preview <session-id>")
        sys.exit(1)

    session_id = sys.argv[1]

    # Load session entries from history
    entries = []
    try:
        with open(HISTORY_FILE, 'r') as f:
            for line in f:
                try:
                    entry = json.loads(line.strip())
                    if entry.get('sessionId') == session_id:
                        entries.append(entry)
                except:
                    pass
    except:
        pass

    if not entries:
        print("=" * 70)
        print(f"SESSION: {session_id}")
        print("=" * 70)
        print("❌ No session data found")
        sys.exit(0)

    # Sort by timestamp
    entries.sort(key=lambda x: x['timestamp'])

    # Session metadata
    msg_count = len(entries)
    start_time = parse_timestamp(entries[0]['timestamp'])
    end_time = parse_timestamp(entries[-1]['timestamp'])
    duration = end_time - start_time
    project = entries[-1].get('project', 'Unknown')

    # Print header
    summary = load_summary(session_id)
    print("=" * 70)
    if summary:
        # Wrap summary to fit width
        words = summary.split()
        line, wrapped = [], []
        for word in words:
            if sum(len(w) + 1 for w in line) + len(word) > 68:
                wrapped.append(' '.join(line))
                line = [word]
            else:
                line.append(word)
        if line:
            wrapped.append(' '.join(line))
        for l in wrapped:
            print(f"  {l}")
        print("=" * 70)
    print(f"📁 Project:   {project}")
    print(f"📅 Started:   {start_time.strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"⏱️  Duration:  {format_duration(duration)}")
    print(f"💬 Messages:  {msg_count}")
    print("=" * 70)
    print()

    # Show conversation
    print("💭 CONVERSATION:")
    print("-" * 70)
    print()

    # Display up to 15 messages with nice formatting
    for i, entry in enumerate(entries[:15], 1):
        msg = entry.get('display', '').strip()
        if not msg:
            continue

        # Timestamp
        ts = parse_timestamp(entry['timestamp'])
        time_str = ts.strftime('%H:%M:%S')

        # Truncate long messages
        if len(msg) > 250:
            msg = msg[:247] + "..."

        # Format with numbering and timestamp
        print(f"{i:2d}. [{time_str}]")
        print(f"    {msg}")
        print()

    if len(entries) > 15:
        print(f"... and {len(entries) - 15} more messages")
        print()

    # Show last message if there are many
    if len(entries) > 15:
        last = entries[-1]
        last_msg = last.get('display', '').strip()
        if last_msg:
            last_ts = parse_timestamp(last['timestamp'])
            print("-" * 70)
            print(f"LATEST MESSAGE [{last_ts.strftime('%H:%M:%S')}]:")
            if len(last_msg) > 250:
                last_msg = last_msg[:247] + "..."
            print(f"    {last_msg}")
            print()

    print("=" * 70)

    # Check if transcript exists
    debug_file = DEBUG_DIR / f"{session_id}.txt"
    if debug_file.exists():
        size_kb = debug_file.stat().st_size / 1024
        print(f"📄 Transcript: {size_kb:.1f} KB available")
    else:
        print("⚠️  No detailed transcript available")


if __name__ == '__main__':
    main()
