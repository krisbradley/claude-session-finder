#!/usr/bin/env python3
"""Export a Claude Code session to a Markdown file and open it."""

import json
import subprocess
import sys
from collections import defaultdict
from datetime import datetime
from pathlib import Path

CLAUDE_DIR = Path.home() / '.claude'
HISTORY_FILE = CLAUDE_DIR / 'history.jsonl'
SUMMARIES_FILE = CLAUDE_DIR / 'csf-summaries.json'
EXPORT_DIR = Path.home() / 'Desktop'

session_id = sys.argv[1].strip() if len(sys.argv) > 1 else ''
if not session_id:
    print("Usage: csf-export <session-id>")
    sys.exit(1)

# Load entries
sessions = defaultdict(list)
with open(HISTORY_FILE) as f:
    for line in f:
        try:
            e = json.loads(line.strip())
            sid = e.get('sessionId', '')
            if sid:
                sessions[sid].append(e)
        except Exception:
            pass

entries = sorted(sessions.get(session_id, []), key=lambda x: x['timestamp'])
if not entries:
    print(f"Session {session_id[:8]} not found")
    sys.exit(1)

# Load summary
summary = None
if SUMMARIES_FILE.exists():
    try:
        data = json.loads(SUMMARIES_FILE.read_text())
        summary = data.get(session_id, {}).get('summary')
    except Exception:
        pass

def fmt_ts(ts):
    return datetime.fromtimestamp(ts / 1000).strftime('%Y-%m-%d %H:%M:%S')

start = datetime.fromtimestamp(entries[0]['timestamp'] / 1000)
end = datetime.fromtimestamp(entries[-1]['timestamp'] / 1000)
duration = end - start
project = entries[-1].get('project', 'Unknown')
try:
    p = Path(project)
    if p.is_relative_to(Path.home()):
        project = f"~/{p.relative_to(Path.home())}"
except Exception:
    pass

lines = [
    f"# Claude Session — {start.strftime('%Y-%m-%d %H:%M')}",
    f"",
    f"| | |",
    f"|---|---|",
    f"| **Project** | `{project}` |",
    f"| **Session ID** | `{session_id}` |",
    f"| **Started** | {start.strftime('%Y-%m-%d %H:%M:%S')} |",
    f"| **Duration** | {str(duration).split('.')[0]} |",
    f"| **Messages** | {len(entries)} |",
    f"",
]

if summary:
    lines += [f"## Summary", f"", f"> {summary}", f""]

lines += [f"## Conversation", f""]

for e in entries:
    msg = e.get('display', '').strip()
    if msg:
        ts = fmt_ts(e['timestamp'])
        lines.append(f"**`{ts}`** {msg}")
        lines.append("")

EXPORT_DIR.mkdir(parents=True, exist_ok=True)
filename = f"claude-session-{start.strftime('%Y%m%d-%H%M%S')}.md"
out_path = EXPORT_DIR / filename
out_path.write_text('\n'.join(lines))

print(f"Exported to {out_path}")
subprocess.run(['open', str(out_path)])
