#!/usr/bin/env python3
"""Full-text search helper for csf fzf integration.
Reads ~/.claude/csf-sessions.tsv and filters by query against full message content.
Usage: csf-search <query>
TSV format: display \t session_id \t project \t full_content
Returns:    display \t session_id \t project
"""

import sys
from pathlib import Path

TSV = Path.home() / '.claude' / 'csf-sessions.tsv'

query = ' '.join(sys.argv[1:]).strip().lower()

try:
    with open(TSV) as f:
        for line in f:
            parts = line.rstrip('\n').split('\t', 3)
            if len(parts) < 4:
                continue
            display, session_id, project, content = parts
            if not query or query in content.lower():
                print(f"{display}\t{session_id}\t{project}")
except Exception:
    sys.exit(1)
