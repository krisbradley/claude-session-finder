#!/usr/bin/env python3
"""Full-text search helper for csf fzf integration.
Reads ~/.claude/csf-sessions.tsv and filters by query.
Usage: csf-search <query>
TSV format: display \t session_id \t project \t title \t full_content
Returns:    display \t session_id \t project

Matching: every query word must appear (AND semantics). Sessions whose
title matches all words are listed first, then content-only matches.
"""

import os
import sys
from pathlib import Path

CLAUDE_DIR = Path(os.environ.get('CLAUDE_CONFIG_DIR', Path.home() / '.claude'))
TSV = CLAUDE_DIR / 'csf-sessions.tsv'

words = ' '.join(sys.argv[1:]).strip().lower().split()

title_matches = []
content_matches = []

try:
    with open(TSV) as f:
        for line in f:
            parts = line.rstrip('\n').split('\t', 4)
            if len(parts) < 5:
                continue
            display, session_id, project, title, content = parts
            row = f"{display}\t{session_id}\t{project}"
            if not words:
                content_matches.append(row)
                continue
            title_lower = title.lower()
            content_lower = content.lower()
            if all(w in title_lower for w in words):
                title_matches.append(row)
            elif all(w in title_lower or w in content_lower for w in words):
                content_matches.append(row)
except Exception:
    sys.exit(1)

for row in title_matches + content_matches:
    print(row)
