#!/usr/bin/env python3
"""Remove a session from Claude Code history and all csf caches."""

import json
import sys
from pathlib import Path

CLAUDE_DIR = Path.home() / '.claude'
HISTORY_FILE = CLAUDE_DIR / 'history.jsonl'
SUMMARIES_FILE = CLAUDE_DIR / 'csf-summaries.json'
TSV_FILE = CLAUDE_DIR / 'csf-sessions.tsv'

session_id = sys.argv[1].strip() if len(sys.argv) > 1 else ''
if not session_id:
    print("Usage: csf-delete <session-id>")
    sys.exit(1)

# Remove from history.jsonl
if not HISTORY_FILE.exists():
    print("No history file found")
    sys.exit(1)

kept = []
removed = 0
with open(HISTORY_FILE) as f:
    for line in f:
        try:
            entry = json.loads(line)
            if entry.get('sessionId') == session_id:
                removed += 1
                continue
        except Exception:
            pass
        kept.append(line)

with open(HISTORY_FILE, 'w') as f:
    f.writelines(kept)

# Remove from summaries cache
if SUMMARIES_FILE.exists():
    try:
        data = json.loads(SUMMARIES_FILE.read_text())
        if session_id in data:
            del data[session_id]
            SUMMARIES_FILE.write_text(json.dumps(data, indent=2))
    except Exception:
        pass

# Remove from TSV cache
if TSV_FILE.exists():
    lines = [l for l in TSV_FILE.read_text().splitlines() if f'\t{session_id}\t' not in l]
    TSV_FILE.write_text('\n'.join(lines))

print(f"Deleted session {session_id[:8]} ({removed} history entries removed)")
