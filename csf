def _parse_project_meta(f: Path) -> Dict[str, str]:
    """Extract name/color/ai_title from a single project JSONL file."""
    markers = ('"custom-title"', '"agent-color"', '"ai-title"')
    entry = {}
    for line in f.open():
        if not any(m in line for m in markers):
            continue
        data = json.loads(line)
        entry_type = data.get('type', '')
        if entry_type == 'custom-title' and data.get('customTitle'):
            entry['name'] = data['customTitle']
        elif entry_type == 'agent-color' and data.get('agentColor'):
            entry['color'] = data['agentColor']
        elif entry_type == 'ai-title' and data.get('aiTitle'):
            entry['ai_title'] = data['aiTitle']
    return entry


def load_session_metadata() -> Dict[str, Dict]:
    """Load name/color/ai-title metadata from project JSONL files and sessions/*.json.

    Project JSONL parses are cached by mtime in csf-meta-cache.json so repeat
    launches don't re-read every session file.
    """
    meta = {}

    try:
        file_cache = json.loads(META_CACHE_FILE.read_text()).get('files', {})
    except Exception:
        file_cache = {}
    new_cache = {}
    dirty = False

    projects_dir = CLAUDE_DIR / 'projects'
    if projects_dir.exists():
        for proj_dir in projects_dir.iterdir():
            if not proj_dir.is_dir():
                continue
            for f in proj_dir.glob('*.jsonl'):
                sid = f.stem
                key = str(f)
                try:
                    mtime = f.stat().st_mtime
                    cached = file_cache.get(key)
                    if cached is not None and cached.get('mtime') == mtime:
                        entry = cached.get('meta', {})
                    else:
                        entry = _parse_project_meta(f)
                        dirty = True
                    new_cache[key] = {'mtime': mtime, 'meta': entry}
                    if entry:
                        meta.setdefault(sid, {}).update(entry)
                except Exception:
                    continue

    if dirty or set(new_cache) != set(file_cache):
        try:
            META_CACHE_FILE.write_text(json.dumps({'files': new_cache}))
        except Exception:
            pass

    if SESSIONS_DIR.exists():
        for f in SESSIONS_DIR.glob('*.json'):
            try:
                for line in f.read_text().splitlines():
                    line = line.strip()
                    if not line:
                        continue
                    data = json.loads(line)
                    sid = data.get('sessionId')
                    if not sid:
                        continue
                    existing = meta.setdefault(sid, {})
                    if data.get('name') and 'name' not in existing:
                        existing['name'] = data['name']
                    if data.get('color') and 'color' not in existing:
                        existing['color'] = data['color']
            except Exception:
                continue

    return meta



def parse_timestamp(ts: int) -> datetime:
    """Convert millisecond timestamp to datetime"""
    return datetime.fromtimestamp(ts / 1000)


def format_time_ago(dt: datetime) -> str:
    """Format datetime as relative time"""
    now = datetime.now()
    diff = now - dt

    if diff.days > 365:
        return f"{diff.days // 365}y"
    elif diff.days > 30:
        return f"{diff.days // 30}mo"
    elif diff.days > 0:
        return f"{diff.days}d"
    elif diff.seconds > 3600:
        return f"{diff.seconds // 3600}h"
    elif diff.seconds > 60:
        return f"{diff.seconds // 60}m"
    else:
        return "now"


def get_session_summary(session_id: str, max_length: int = 100) -> str:
    """Extract a summary from the session transcript"""
    debug_file = DEBUG_DIR / f"{session_id}.txt"

    if not debug_file.exists():
        return "No transcript available"

    try:
        with open(debug_file, 'r', encoding='utf-8') as f:
            content = f.read(5000)  # Read first 5KB

            # Look for the first user message
            lines = content.split('\n')
            for line in lines:
                if line.strip() and not line.startswith('['):
                    # Clean up the line
                    summary = line.strip()
                    if len(summary) > max_length:
                        summary = summary[:max_length] + "..."
                    return summary

            return "Empty session"
    except Exception as e:
        return f"Error reading transcript: {e}"


def create_preview_summary(session_id: str, entries: List[Dict]) -> str:
    """Create a formatted preview summary for fzf"""
    debug_file = DEBUG_DIR / f"{session_id}.txt"

    # Header
    msg_count = len(entries)
    latest = max(entries, key=lambda x: x['timestamp'])
    oldest = min(entries, key=lambda x: x['timestamp'])

    start_time = parse_timestamp(oldest['timestamp'])
    end_time = parse_timestamp(latest['timestamp'])
    duration = end_time - start_time

    project = latest.get('project', 'Unknown')

    lines = []
    lines.append("=" * 60)
    lines.append(f"SESSION: {session_id}")
    lines.append("=" * 60)
    lines.append(f"Project:   {project}")
    lines.append(f"Started:   {start_time.strftime('%Y-%m-%d %H:%M:%S')}")
    lines.append(f"Duration:  {format_duration(duration)}")
    lines.append(f"Messages:  {msg_count}")
    lines.append("=" * 60)
    lines.append("")

    # Try to extract conversation
    if debug_file.exists():
        try:
            with open(debug_file, 'r', encoding='utf-8') as f:
                content = f.read(50000)  # Read more for better context

                # Extract key interactions
                lines.append("CONVERSATION SUMMARY:")
                lines.append("-" * 60)

                # Parse the transcript for user messages and tool calls
                conversation = parse_transcript_for_preview(content)

                for item in conversation[:15]:  # Show first 15 items
                    lines.append(item)
                    lines.append("")

                if len(conversation) > 15:
                    lines.append(f"... and {len(conversation) - 15} more interactions")

        except Exception as e:
            lines.append(f"Error reading transcript: {e}")
    else:
        lines.append("No transcript available")

    return '\n'.join(lines)


def format_duration(delta) -> str:
    """Format timedelta as human readable duration"""
    total_seconds = int(delta.total_seconds())
    if total_seconds < 60:
        return f"{total_seconds}s"
    elif total_seconds < 3600:
        return f"{total_seconds // 60}m {total_seconds % 60}s"
    elif total_seconds < 86400:
        hours = total_seconds // 3600
        minutes = (total_seconds % 3600) // 60
        return f"{hours}h {minutes}m"
    else:
        days = total_seconds // 86400
        hours = (total_seconds % 86400) // 3600
        return f"{days}d {hours}h"


def generate_session_title(entries: List[Dict]) -> str:
    """Generate a descriptive title for a session based on its messages"""
    if not entries:
        return None

    # Get first several messages to understand the topic
    messages = [e.get('display', '').strip() for e in entries[:10] if e.get('display', '').strip()]

    if not messages:
        return None

    # Filter out messages that are just special characters or very short
    meaningful_messages = [m for m in messages if len(m) > 5 and any(c.isalnum() for c in m)]

    if not meaningful_messages:
        return None

    # Use meaningful messages from here on
    messages = meaningful_messages

    # Skip sessions that are just commands like "/resume"
    if all(msg.startswith('/') or len(msg) < 5 for msg in messages[:3]):
        return None

    # Need at least one substantial message (>15 chars)
    if not any(len(msg) > 15 for msg in messages[:3]):
        return None

    # Combine first few messages for analysis
    combined = ' '.join(messages[:5]).lower()

    # Identify important technical terms and proper nouns (capitalized or commonly known)
    tech_terms = ['salesforce', 'github', 'git', 'docker', 'kubernetes', 'aws', 'api', 'database',
                  'sql', 'python', 'javascript', 'typescript', 'react', 'node', 'npm', 'jira',
                  'confluence', 'slack', 'oauth', 'jwt', 'token', 'authentication', 'authorization',
                  'deployment', 'cicd', 'pipeline', 'workflow', 'fastpath', 'copado', 'zuora',
                  'netsuite', 'datadog', 'splunk', 'snowflake', 'sfdx', 'apex']

    # Find important terms in the combined messages
    important_terms = []
    for term in tech_terms:
        if term in combined:
            important_terms.append(term.capitalize() if term.islower() else term)

    # Build a descriptive title
    # Skip generic first messages like "commit this", "push it"
    first_msg = messages[0]
    quick_bad = ['commit this', 'push it', 'push this', 'save this', 'commit', 'push']
    if len(messages) > 1:
        for msg in messages[:5]:
            is_generic = False
            msg_lower = msg.lower().strip()
            for bad in quick_bad:
                if msg_lower == bad or (msg_lower.startswith(bad + ' ') and len(msg) < 20):
                    is_generic = True
                    break
            if not is_generic and len(msg) > 15:
                first_msg = msg
                break

    # Strip common filler phrases more aggressively
    strip_phrases = [
        'can you ', 'could you ', 'please ', 'help me ', 'i need ', 'i want ',
        'i would like ', 'would you ', 'can we ', "let's ", 'lets ',
        'i have ', 'there is ', 'there are ', 'i got ', 'i see ',
        'i am ', "i'm ", 'we need ', 'we should '
    ]

    title = first_msg
    for phrase in strip_phrases:
        title = title.replace(phrase, '')
        title = title.replace(phrase.capitalize(), '')

    title = title.strip()

    # If title is too generic after stripping, try to enhance with important terms
    if len(title) < 15 and important_terms:
        # Build a better title from context
        if important_terms:
            title = f"Working with {important_terms[0]}"
            if len(important_terms) > 1:
                title += f" and {important_terms[1]}"

    # Capitalize first letter
    if title and len(title) > 0:
        title = title[0].upper() + title[1:]

    # Truncate intelligently
    if len(title) > 55:
        if ' ' in title[45:55]:
            cut_point = title.rfind(' ', 45, 55)
            if cut_point > 35:
                title = title[:cut_point] + "..."
            else:
                title = title[:52] + "..."
        else:
            title = title[:52] + "..."

    # Final validation - filter out non-descriptive titles
    title_lower = title.lower().strip()

    # List of patterns that indicate non-descriptive sessions
    bad_patterns = [
        '/resume', '/model', '/help', '/start', '/commit',
        'resume', 'model', 'help', 'start', 'commit this', 'push it',
        'push this', 'commit', 'save', 'ok', 'yes', 'no', 'sure',
        'thanks', 'thank you', 'done', 'great', 'perfect', 'sounds good',
        'go ahead', 'continue', 'proceed', 'next', 'please',
        'got it', 'i see', 'understood', 'looks good', 'message',
        'a message', 'the message', 'hi team', 'team', 'window',
        'page', 'open', 'close', 'click'
    ]

    # Check if title is too generic
    if not title or len(title) < 15:
        return None

    # Check against bad patterns
    for pattern in bad_patterns:
        if title_lower == pattern or title_lower.startswith(pattern + ' ') or title_lower.startswith(pattern + ','):
            return None

    if len(title) < 12:
        return None

    return title


def parse_transcript_for_preview(content: str) -> List[str]:
    """Parse transcript and extract key information for preview"""
    lines = content.split('\n')
    items = []
    current_block = []
    block_type = None

    for line in lines[:500]:  # Process first 500 lines
        line = line.strip()

        # Detect user messages
        if line.startswith('[USER]') or (not line.startswith('[') and line and len(current_block) == 0):
            if current_block and block_type:
                items.append(format_preview_block(block_type, current_block))
            current_block = [line.replace('[USER]', '').strip()]
            block_type = 'user'

        # Detect tool usage
        elif 'Tool:' in line or 'Bash:' in line or 'Read:' in line or 'Write:' in line or 'Edit:' in line:
            if current_block and block_type:
                items.append(format_preview_block(block_type, current_block))
            current_block = [line]
            block_type = 'tool'

        # Detect Claude responses
        elif line.startswith('[CLAUDE]') or line.startswith('[Assistant]'):
            if current_block and block_type:
                items.append(format_preview_block(block_type, current_block))
            current_block = [line.replace('[CLAUDE]', '').replace('[Assistant]', '').strip()]
            block_type = 'claude'

        # Continue current block
        elif current_block and line:
            current_block.append(line)
            if len(current_block) > 5:  # Limit block size
                break

    # Add last block
    if current_block and block_type:
        items.append(format_preview_block(block_type, current_block))

    return items


def format_preview_block(block_type: str, lines: List[str]) -> str:
    """Format a block for preview display"""
    if block_type == 'user':
        text = ' '.join(lines[:3])  # First 3 lines
        if len(text) > 200:
            text = text[:197] + "..."
        return f"👤 USER: {text}"

    elif block_type == 'claude':
        text = ' '.join(lines[:3])
        if len(text) > 200:
            text = text[:197] + "..."
        return f"🤖 CLAUDE: {text}"

    elif block_type == 'tool':
        text = ' '.join(lines[:2])
        if len(text) > 200:
            text = text[:197] + "..."
        return f"🔧 TOOL: {text}"

    return ""


def resumable_session_ids() -> set:
    """Session IDs whose transcript still exists on disk (claude --resume works)."""
    ids = set()
    projects_dir = CLAUDE_DIR / 'projects'
    if projects_dir.exists():
        for proj_dir in projects_dir.iterdir():
            if proj_dir.is_dir():
                for f in proj_dir.glob('*.jsonl'):
                    ids.add(f.stem)
    return ids


def load_sessions() -> List[Dict]:
    """Load all sessions from history.jsonl"""
    if not HISTORY_FILE.exists():
        print(f"{YELLOW}No history file found at {HISTORY_FILE}{RESET}")
        return []

    sessions = []
    with open(HISTORY_FILE, 'r') as f:
        for line in f:
            try:
                session = json.loads(line.strip())
                sessions.append(session)
            except json.JSONDecodeError:
                continue

    return sessions


def group_sessions_by_id(sessions: List[Dict], min_messages: int = 2) -> Dict[str, List[Dict]]:
    """Group sessions by sessionId and filter out sessions with too few messages"""
    grouped = defaultdict(list)
    for session in sessions:
        session_id = session.get('sessionId')
        if session_id:
            grouped[session_id].append(session)

    # Filter out sessions with fewer than min_messages
    filtered = {sid: msgs for sid, msgs in grouped.items() if len(msgs) >= min_messages}
    return filtered


def resolve_session_title(session_id: str, entries: List[Dict], session_meta: Dict) -> Optional[str]:
    """Resolve a session's display title: user name > ai-title > generated."""
    meta = session_meta.get(session_id, {})
    user_name = meta.get('name')
    ai_title = meta.get('ai_title')

    if user_name:
        return user_name
    elif ai_title:
        return ai_title
    else:
        return generate_session_title(entries)


def get_session_color(session_id: str, session_meta: Dict) -> Optional[str]:
    """Return the ANSI color code for a session's user-assigned color, if any."""
    meta = session_meta.get(session_id, {})
    color_name = meta.get('color', '').lower()
    return COLOR_ANSI.get(color_name)


def print_sessions(grouped_sessions: Dict[str, List[Dict]]):
    """Print formatted list of sessions"""
    session_meta = load_session_metadata()

    # Sort by most recent first
    sorted_sessions = sorted(
        grouped_sessions.items(),
        key=lambda x: max(s['timestamp'] for s in x[1]),
        reverse=True
    )

    print(f"\n{BOLD}{CYAN}Claude Code Sessions{RESET}\n")

    printed = 0
    for session_id, entries in sorted_sessions[:50]:  # Show last 50 sessions
        # Get the most recent entry for this session
        latest = max(entries, key=lambda x: x['timestamp'])
        timestamp = parse_timestamp(latest['timestamp'])
        time_ago = format_time_ago(timestamp)

        # Get project directory (relative to home if possible)
        project = latest.get('project', 'Unknown')
        try:
            project_path = Path(project)
            if project_path.is_relative_to(Path.home()):
                project = f"~/{project_path.relative_to(Path.home())}"
        except (ValueError, AttributeError):
            pass

        session_title = resolve_session_title(session_id, entries, session_meta)

        # Skip sessions with no meaningful title
        if not session_title:
            continue

        printed += 1

        # Count messages in session
        msg_count = len(entries)

        # Format output
        session_color = get_session_color(session_id, session_meta)
        title_display = f"{session_color}{session_title}{RESET}" if session_color else session_title
        print(f"{DIM}{printed:2d}.{RESET} {GREEN}{time_ago:>3}{RESET} {DIM}│{RESET} {msg_count:>3} {DIM}│{RESET} {BLUE}{project}{RESET}")
        print(f"    {title_display}")
        print(f"    {DIM}[{session_id[:8]}]{RESET}")
        print()

    print(f"{DIM}Showing {printed} of {len(sorted_sessions)} sessions{RESET}\n")

    # Return sessions with valid titles only
    valid_sessions = []
    for session_id, entries in sorted_sessions[:50]:
        if generate_session_title(entries):
            valid_sessions.append((session_id, entries))
    return valid_sessions


def select_session_fzf(grouped_sessions: Dict[str, List[Dict]], initial_query: str = '') -> tuple:
    """Use fzf for interactive session selection.

    Returns (session_id, fork): fork is True when the user picked with ctrl-f.
    """
    session_meta = load_session_metadata()

    # Sort by most recent first
    sorted_sessions = sorted(
        grouped_sessions.items(),
        key=lambda x: max(s['timestamp'] for s in x[1]),
        reverse=True
    )

    # Prepare fzf input
    fzf_input = []
    for session_id, entries in sorted_sessions[:100]:  # Limit to 100 most recent
        latest = max(entries, key=lambda x: x['timestamp'])
        timestamp = parse_timestamp(latest['timestamp'])
        time_ago = format_time_ago(timestamp)

        session_title = resolve_session_title(session_id, entries, session_meta)

        # Skip sessions with no meaningful title
        if not session_title:
            continue

        msg_count = len(entries)

        # Collect all message content for full-text search
        all_messages = ' '.join([e.get('display', '').strip() for e in entries if e.get('display', '').strip()])

        # CRITICAL: Remove tabs and newlines to prevent breaking TSV format
        all_messages = all_messages.replace('\t', ' ').replace('\n', ' ').replace('\r', ' ')

        # Skip if no actual content or too short
        if not all_messages or len(all_messages) < 20:
            continue

        # Make sure there's alphanumeric content
        if not any(c.isalnum() for c in all_messages):
            continue

        # Get project for searchability
        project = latest.get('project', '')
        try:
            project_path = Path(project)
            if project_path.is_relative_to(Path.home()):
                project = str(project_path.relative_to(Path.home()))
        except (ValueError, AttributeError):
            pass

        meta = session_meta.get(session_id, {})
        has_user_name = bool(meta.get('name'))
        if not session_title or (not has_user_name and len(session_title.strip()) < 15):
            continue

        # Color the time based on recency
        if time_ago in ('now',) or time_ago.endswith('m'):
            time_color = '\033[92m'   # bright green  = recent
        elif time_ago.endswith('h'):
            time_color = '\033[32m'   # green
        elif time_ago.endswith('d') and int(time_ago[:-1].strip()) <= 3:
            time_color = '\033[33m'   # yellow
        else:
            time_color = '\033[2;37m' # dim white = older

        # Apply session color if set
        session_color = get_session_color(session_id, session_meta)
        if session_color:
            title_str = f"{session_color}{session_title}{'\033[0m'}"
        else:
            title_str = session_title

        reset = '\033[0m'
        dim = '\033[2m'
        cyan = '\033[36m'

        display_line = (
            f"{time_color}{time_ago:>3}{reset} "
            f"{dim}│{reset} "
            f"{cyan}{msg_count:>3}{reset} "
            f"{dim}│{reset} "
            f"{title_str}"
        )
        # Plain title (no ANSI) so the search helper can match against it
        title_plain = session_title.replace('\t', ' ').replace('\n', ' ')

        # TSV row: display \t session_id \t project \t title \t full_content
        fzf_input.append(f"{display_line}\t{session_id}\t{project}\t{title_plain}\t{all_messages}")

    # Check if we have any sessions to display
    if not fzf_input:
        print(f"\n{YELLOW}No sessions with meaningful content found.{RESET}")
        print(f"All sessions have been filtered out (commands only, too short, etc.)")
        return None, False

    # Write TSV cache for the search helper: display \t session_id \t project \t title \t full_content
    tsv_file = CLAUDE_DIR / 'csf-sessions.tsv'
    with open(tsv_file, 'w') as f:
        f.write('\n'.join(fzf_input))

    # Initial display input: display \t session_id \t project
    display_input = '\n'.join(
        '\t'.join(line.split('\t')[:3]) for line in fzf_input
    )

    def find_script(name):
        found = shutil.which(name)
        if not found:
            raise FileNotFoundError(f"{name} not found in PATH")
        return found

    search_script = find_script('csf-search')
    preview_script = find_script('csf-preview')
    delete_script = find_script('csf-delete')
    export_script = find_script('csf-export')
    fzf_extra = []
    if initial_query:
        # Pre-fill the query and apply it immediately (change: only fires on typing)
        fzf_extra = ['--query', initial_query, '--bind', f'start:reload({search_script} {{q}})']

    try:
        result = subprocess.run(
            [
                'fzf',
                *fzf_extra,
                '--height', '80%',
                '--reverse',
                '--border',
                '--border-label', '\033[1;38;2;187;154;247m ✦ \033[38;2;192;202;245mClaude Session Finder\033[1;38;2;187;154;247m ✦ \033[0m',
                '--list-label', ' enter open  ^f fork  ^d delete  ^e export  ^y copy id  ^p project ',
                '--expect', 'ctrl-f',
                '--list-label-pos', '-1',
                '--header', f'time\033[2m│\033[0m   # \033[2m│\033[0m description',
                '--prompt', '  ',
                '--pointer', '❯',
                '--marker', '●',
                '--delimiter', '\t',
                '--with-nth', '1',
                '--disabled',
                '--bind', f'change:reload({search_script} {{q}})',
                '--bind', f'ctrl-d:execute({delete_script} {{2}})+reload({search_script} {{q}})',
                '--bind', f'ctrl-y:execute(echo -n {{2}} | pbcopy)',
                '--bind', f'ctrl-e:execute({export_script} {{2}})',
                '--bind', f'ctrl-p:execute(open {{3}})',
                '--preview', f'{preview_script} {{2}}',
                '--preview-window', 'right:55%:border-left',
                '--ansi',
                '--color', (
                    'fg:#c0caf5,fg+:#c0caf5,'
                    'bg:#1a1b26,bg+:#292e42,'
                    'hl:#7aa2f7,hl+:#7dcfff,'
                    'border:#3b4261,'
                    'label:#7aa2f7,'
                    'prompt:#bb9af7,'
                    'pointer:#f7768e,'
                    'marker:#9ece6a,'
                    'header:#565f89,'
                    'info:#e0af68,'
                    'spinner:#f7768e'
                )
            ],
            input=display_input,
            capture_output=True,
            text=True
        )

        if result.returncode == 0 and result.stdout.strip():
            # With --expect, line 1 is the pressed key ('' for enter), line 2 the selection
            lines = result.stdout.splitlines()
            fork = lines[0].strip() == 'ctrl-f' if lines else False
            selection = lines[1] if len(lines) > 1 else ''
            parts = selection.split('\t')
            if len(parts) > 1:
                return parts[1], fork
    except FileNotFoundError:
        print(f"{YELLOW}fzf not found. Install with: brew install fzf{RESET}")
    except Exception as e:
        print(f"{YELLOW}Error running fzf: {e}{RESET}")
    return None, False


def open_session(session_id: str, entries: List[Dict], title: Optional[str] = None, fork: bool = False):
    """Open a Claude session, optionally as a fork (new session ID, same history)"""
    latest = max(entries, key=lambda x: x['timestamp'])
    project = latest.get('project', os.getcwd())

    verb = 'Forking' if fork else 'Opening'
    label = f'"{title}" ({session_id[:8]})' if title else f'session {session_id[:8]}'
    print(f"\n{GREEN}{verb} {label} in {project}...{RESET}\n")

    cmd = ['claude', '--resume', session_id]
    if fork:
        cmd.append('--fork-session')

    try:
        os.chdir(project)
        subprocess.run(cmd)
    except Exception as e:
        print(f"{YELLOW}Error opening session: {e}{RESET}")
        print(f"Try running: cd {project} && {' '.join(cmd)}")


def filter_by_date(grouped: Dict[str, List[Dict]], days: int) -> Dict[str, List[Dict]]:
    """Keep only sessions with activity within the last `days` days (0 = today)."""
    cutoff = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
    if days > 0:
        cutoff -= timedelta(days=days - 1)
    return {
        sid: entries for sid, entries in grouped.items()
        if parse_timestamp(max(e['timestamp'] for e in entries)) >= cutoff
    }


def show_stats(grouped: Dict[str, List[Dict]]):
    """Print a dashboard of session statistics."""
    all_entries = [e for entries in grouped.values() for e in entries]
    total_sessions = len(grouped)
    total_messages = len(all_entries)

    # Sessions per day (last 7 days)
    today = datetime.now().date()
    day_counts = defaultdict(int)
    for sid, entries in grouped.items():
        latest = parse_timestamp(max(e['timestamp'] for e in entries))
        day_counts[latest.date()] += 1

    # Top projects
    project_counts = defaultdict(int)
    for sid, entries in grouped.items():
        project = max(entries, key=lambda e: e['timestamp']).get('project', 'Unknown')
        try:
            p = Path(project)
            if p.is_relative_to(Path.home()):
                project = f"~/{p.relative_to(Path.home())}"
        except Exception:
            pass
        project_counts[project] += 1

    w = 54
    bar_max = 20

    def bar(n, total, width=12):
        filled = round(n / total * width) if total else 0
        return f"{'█' * filled}{'░' * (width - filled)}"

    print(f"\n{BOLD}{CYAN}{'━' * w}{RESET}")
    print(f"{BOLD}{CYAN}  Claude Session Stats{RESET}")
    print(f"{BOLD}{CYAN}{'━' * w}{RESET}\n")
    print(f"  {BOLD}Total sessions:{RESET}  {GREEN}{total_sessions}{RESET}     {BOLD}Total messages:{RESET}  {GREEN}{total_messages}{RESET}\n")

    print(f"  {BOLD}Activity — last 7 days:{RESET}")
    for i in range(6, -1, -1):
        day = today - timedelta(days=i)
        count = day_counts.get(day, 0)
        label = "today" if i == 0 else day.strftime("%a %b %-d")
        filled = round(count / max(max(day_counts.values(), default=1), 1) * bar_max)
        b = f"{GREEN}{'█' * filled}{DIM}{'░' * (bar_max - filled)}{RESET}"
        print(f"    {DIM}{label:>12}{RESET}  {b}  {count}")
    print()

    print(f"  {BOLD}Top projects:{RESET}")
    for project, count in sorted(project_counts.items(), key=lambda x: -x[1])[:5]:
        b = bar(count, total_sessions)
        print(f"    {BLUE}{project:<30}{RESET}  {b}  {count}")
    print()

    print(f"\n{BOLD}{CYAN}{'━' * w}{RESET}\n")


def select_by_project(grouped: Dict[str, List[Dict]]):
    """Two-step fzf: pick a project, then pick a session within it."""
    project_map = defaultdict(list)
    for sid, entries in grouped.items():
        latest = max(entries, key=lambda e: e['timestamp'])
        project = latest.get('project', 'Unknown')
        try:
            p = Path(project)
            if p.is_relative_to(Path.home()):
                project = f"~/{p.relative_to(Path.home())}"
        except Exception:
            pass
        project_map[project].append((sid, entries))

    # Build project list for fzf
    project_lines = []
    for project, sessions in sorted(project_map.items(), key=lambda x: -len(x[1])):
        latest_ts = max(
            max(e['timestamp'] for e in entries)
            for _, entries in sessions
        )
        time_ago = format_time_ago(parse_timestamp(latest_ts))
        project_lines.append(f"{len(sessions):>3} sessions  {GREEN}{time_ago:>8}{RESET}  {BLUE}{project}{RESET}")

    result = subprocess.run(
        ['fzf', '--ansi', '--reverse', '--border',
         '--border-label', '\033[1;38;2;187;154;247m ✦ \033[38;2;192;202;245mChoose a Project\033[1;38;2;187;154;247m ✦ \033[0m',
         '--prompt', '  ', '--pointer', '❯',
         '--color', 'fg:#c0caf5,bg:#1a1b26,bg+:#292e42,hl:#7aa2f7,border:#3b4261,label:#7aa2f7,prompt:#bb9af7,pointer:#f7768e,marker:#9ece6a,info:#e0af68'],
        input='\n'.join(project_lines),
        capture_output=True, text=True
    )

    if result.returncode != 0 or not result.stdout.strip():
        return

    # Extract project name (last token after ANSI reset)
    import re
    selected_line = result.stdout.strip()
    clean = re.sub(r'\033\[[0-9;]*m', '', selected_line)
    # project name is the last field
    project_name = clean.split()[-1]

    # Find matching project (fuzzy match on cleaned name)
    matched = None
    for project, sessions in project_map.items():
        if project.endswith(project_name) or project_name in project:
            matched = (project, sessions)
            break

    if not matched:
        return

    _, sessions = matched
    filtered = {sid: entries for sid, entries in sessions}
    selected_id = select_session_fzf(filtered)
    if selected_id and selected_id in grouped:
        open_session(selected_id, grouped[selected_id])


def main():
    parser = argparse.ArgumentParser(description='Browse and resume Claude Code sessions')
    parser.add_argument('query', nargs='*', help='Search and open the top matching session')
    parser.add_argument('--version', action='version', version=f'csf {__version__}')
    parser.add_argument('--last', action='store_true', help="Resume the most recent session (same as 'csf -')")
    parser.add_argument('--stats', action='store_true', help='Show session statistics')
    parser.add_argument('--projects', action='store_true', help='Browse sessions by project')
    parser.add_argument('--today', action='store_true', help='Show only today\'s sessions')
    parser.add_argument('--week', action='store_true', help='Show only this week\'s sessions')
    args = parser.parse_args()

    if not HISTORY_FILE.exists():
        print(f"{YELLOW}No Claude Code history found.{RESET}")
        print(f"Run Claude Code first to create sessions.")
        sys.exit(1)

    sessions = load_sessions()
    if not sessions:
        print(f"{YELLOW}No sessions found in history.{RESET}")
        sys.exit(1)

    grouped = group_sessions_by_id(sessions)

    # Hide sessions whose transcript was pruned — claude --resume would fail
    resumable = resumable_session_ids()
    grouped = {sid: entries for sid, entries in grouped.items() if sid in resumable}
    if not grouped:
        print(f"{YELLOW}No resumable sessions found.{RESET}")
        print("Session transcripts in ~/.claude/projects/ may have been cleaned up.")
        sys.exit(1)

    if args.stats:
        show_stats(grouped)
        return

    if args.today:
        grouped = filter_by_date(grouped, days=0)
        if not grouped:
            print(f"{YELLOW}No sessions today.{RESET}")
            return

    elif args.week:
        grouped = filter_by_date(grouped, days=7)
        if not grouped:
            print(f"{YELLOW}No sessions this week.{RESET}")
            return

    if args.projects:
        select_by_project(grouped)
        return

    if args.last or args.query == ['-']:
        session_meta = load_session_metadata()
        session_id, entries = max(grouped.items(), key=lambda x: max(s['timestamp'] for s in x[1]))
        title = resolve_session_title(session_id, entries, session_meta)
        open_session(session_id, entries, title)
        return

    if args.query:
        query = ' '.join(args.query)
        words = query.lower().split()
        session_meta = load_session_metadata()
        sorted_sessions = sorted(
            grouped.items(),
            key=lambda x: max(s['timestamp'] for s in x[1]),
            reverse=True
        )

        # Priority 1: sessions whose title matches every query word
        title_matches = []
        for session_id, entries in sorted_sessions:
            title = resolve_session_title(session_id, entries, session_meta) or ''
            if title and all(w in title.lower() for w in words):
                title_matches.append((session_id, entries, title))

        if len(title_matches) == 1:
            session_id, entries, title = title_matches[0]
            open_session(session_id, entries, title)
            return
        if len(title_matches) > 1:
            selected_id, fork = select_session_fzf(grouped, initial_query=query)
            if selected_id and selected_id in grouped:
                open_session(selected_id, grouped[selected_id], fork=fork)
            return

        # Priority 2: sessions whose message content matches every query word
        for session_id, entries in sorted_sessions:
            all_text = ' '.join(e.get('display', '') for e in entries).lower()
            if all(w in all_text for w in words):
                title = resolve_session_title(session_id, entries, session_meta)
                open_session(session_id, entries, title)
                return
        print(f"{YELLOW}No sessions matching '{query}'.{RESET}")
        return

    fzf_available = subprocess.run(['which', 'fzf'], capture_output=True).returncode == 0

    if fzf_available:
        selected_id, fork = select_session_fzf(grouped)
        if selected_id and selected_id in grouped:
            open_session(selected_id, grouped[selected_id], fork=fork)
    else:
        print(f"{YELLOW}Tip: Install fzf for interactive selection: brew install fzf{RESET}\n")
        sorted_sessions = print_sessions(grouped)
        try:
            choice = input(f"{BOLD}Enter session number (or 'q' to quit): {RESET}")
            if choice.lower() == 'q':
                sys.exit(0)
            idx = int(choice) - 1
            if 0 <= idx < len(sorted_sessions):
                session_id, entries = sorted_sessions[idx]
                open_session(session_id, entries)
            else:
                print(f"{YELLOW}Invalid selection{RESET}")
        except (ValueError, KeyboardInterrupt):
            print(f"\n{YELLOW}Cancelled{RESET}")
            sys.exit(0)


if __name__ == '__main__':
    main()
